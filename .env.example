# ============================================================================
# Startup Visa Roads — environment variables
# Copy to .env (local dev) / set in your hosting provider (production).
# ============================================================================

# Database (dev uses SQLite, production uses PostgreSQL)
DATABASE_URL="file:./dev.db"
# DIRECT_URL is used by some Postgres providers (e.g. Supabase pooled vs direct)
DIRECT_URL=""

# Public site origin — REQUIRED for correct canonical URLs, sitemap, OG tags.
# No trailing slash. e.g. https://visaroads.com
#
# Two ways to set it:
#  - NEXT_PUBLIC_SITE_URL : baked at BUILD time (statically generated pages).
#                           On Cloud Run pass it as a Docker build-arg.
#  - SITE_URL             : RUNTIME env (Cloud Run service var). Overrides the
#                           above for dynamic routes (sitemap.xml, article
#                           canonicals) — set this to your real domain so you
#                           don't have to rebuild just to change the URL.
SITE_URL="https://visaroads.com"
NEXT_PUBLIC_SITE_URL="https://visaroads.com"

# Admin auth — REQUIRED.
ADMIN_USERNAME="admin"
# Provide EITHER a plaintext password OR (preferred) its SHA-256 hex hash.
# Generate a hash:  node -e "crypto.subtle.digest('SHA-256', new TextEncoder().encode('YOUR_PASSWORD')).then(d=>console.log(Buffer.from(d).toString('hex')))"
ADMIN_PASSWORD=""
ADMIN_PASSWORD_HASH=""

# JWT signing secret — REQUIRED, minimum 16 characters, use a long random value.
# Generate:  openssl rand -hex 32
JWT_SECRET=""

# Cron auto-pilot secret (protects /api/cron/generate)
CRON_SECRET=""

# AI providers
OPENAI_API_KEY=""
FAL_KEY=""

# Object storage for images (S3-compatible: Google Cloud Storage, Cloudflare R2,
# AWS S3, B2, MinIO...). If unset, images are stored inline as base64 (works,
# but bloats the DB and hurts Core Web Vitals). Setting these moves images to a
# CDN — strongly recommended for production SEO/performance.
#
# Google Cloud Storage (interoperability / HMAC keys):
#   S3_ENDPOINT=https://storage.googleapis.com
#   S3_BUCKET=<your-bucket>
#   S3_REGION=<bucket-location, e.g. us-central1 or us>   # must match the bucket
#   S3_ACCESS_KEY_ID / S3_SECRET_ACCESS_KEY = a service-account HMAC key
#     (Cloud Storage → Settings → Interoperability → Create key)
#   S3_PUBLIC_BASE_URL=https://storage.googleapis.com/<your-bucket>
#     (bucket must allow public read, or front it with Cloud CDN)
S3_ENDPOINT=""
S3_BUCKET=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_REGION="auto"
S3_PUBLIC_BASE_URL=""
S3_KEY_PREFIX="uploads"

# Lead notifications (Telegram)
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# Social Media Auto-Publishing (optional)
# LinkedIn
LINKEDIN_ACCESS_TOKEN=""
LINKEDIN_AUTHOR_URN="" # e.g. urn:li:organization:12345 or urn:li:person:67890

# Twitter (X) - OAuth 1.0a User Context (does not expire)
TWITTER_CONSUMER_KEY=""
TWITTER_CONSUMER_SECRET=""
TWITTER_ACCESS_TOKEN=""
TWITTER_ACCESS_SECRET=""

# Facebook
FACEBOOK_PAGE_ACCESS_TOKEN=""
FACEBOOK_PAGE_ID=""

