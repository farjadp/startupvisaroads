# ============================================================================
# Startup Visa Roads — environment variables
# Copy to .env (local dev) / set in your hosting provider (production).
# ============================================================================

# Database (dev uses SQLite, production uses PostgreSQL)
DATABASE_URL="file:./dev.db"
# DIRECT_URL is used by some Postgres providers (e.g. Supabase pooled vs direct)
DIRECT_URL=""

# Public site origin — REQUIRED for correct canonical URLs, sitemap, OG tags.
# No trailing slash. e.g. https://startupvisaroads.com
NEXT_PUBLIC_SITE_URL="https://startupvisaroads.com"

# Admin auth — REQUIRED.
ADMIN_USERNAME="admin"
# Provide EITHER a plaintext password OR (preferred) its SHA-256 hex hash.
# Generate a hash:  node -e "crypto.subtle.digest('SHA-256', new TextEncoder().encode('YOUR_PASSWORD')).then(d=>console.log(Buffer.from(d).toString('hex')))"
ADMIN_PASSWORD=""
ADMIN_PASSWORD_HASH=""

# JWT signing secret — REQUIRED, minimum 16 characters, use a long random value.
# Generate:  openssl rand -hex 32
JWT_SECRET=""

# Cron auto-pilot secret (protects /api/cron/generate)
CRON_SECRET=""

# AI providers
OPENAI_API_KEY=""
FAL_KEY=""

# Lead notifications (Telegram)
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""
