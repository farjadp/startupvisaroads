datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model PageView {
  id        String   @id @default(cuid())
  path      String
  createdAt DateTime @default(now())
}

model Article {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  excerpt     String?
  content     String   // HTML content
  coverImage  String?
  status      String   @default("DRAFT") // DRAFT or PUBLISHED
  locale      String   @default("en") // en or fa
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id])

  tags        Tag[]     @relation("ArticleTags")

  @@index([locale, status, createdAt])
}

model Category {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  articles  Article[]
}

model Tag {
  id        String    @id @default(cuid())
  name      String    @unique
  articles  Article[] @relation("ArticleTags")
}

model AiKeyword {
  id        String   @id @default(cuid())
  keyword   String
  status    String   @default("PENDING") // PENDING, PROCESSING, COMPLETED, ERROR
  error     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
