datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model PageView {
  id        String   @id @default(cuid())
  path      String
  createdAt DateTime @default(now())
}

model Article {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  excerpt     String?
  content     String   // HTML content
  coverImage  String?
  status      String   @default("DRAFT") // DRAFT or PUBLISHED
  locale      String   @default("en") // en or fa
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id])

  tags        Tag[]     @relation("ArticleTags")

  sharedToLinkedin Boolean @default(false)
  sharedToTwitter  Boolean @default(false)
  sharedToFacebook Boolean @default(false)

  @@index([locale, status, createdAt])
}

model Category {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  articles  Article[]
}

model Tag {
  id        String    @id @default(cuid())
  name      String    @unique
  articles  Article[] @relation("ArticleTags")
}

model AiKeyword {
  id        String   @id @default(cuid())
  keyword   String
  status    String   @default("PENDING") // PENDING, PROCESSING, COMPLETED, ERROR
  error     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Setting {
  key   String @id
  value String
}

// ─── Marketing ───────────────────────────────────────────────────────────────

model MarketingContact {
  id        String              @id @default(cuid())
  email     String?
  phone     String?
  name      String?
  tags      String[]            @default([])
  groupId   String?
  group     MarketingGroup?     @relation(fields: [groupId], references: [id])
  createdAt DateTime            @default(now())
  @@index([email])
  @@index([groupId])
}

model MarketingGroup {
  id        String               @id @default(cuid())
  name      String
  color     String               @default("#CCFF00")
  contacts  MarketingContact[]
  campaigns CampaignGroup[]
  createdAt DateTime             @default(now())
}

model Campaign {
  id          String          @id @default(cuid())
  name        String
  type        String          @default("EMAIL")
  status      String          @default("DRAFT")
  subject     String?
  body        String          @default("")
  smsBody     String?
  scheduledAt DateTime?
  sentAt      DateTime?
  groups      CampaignGroup[]
  logs        CampaignLog[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model CampaignGroup {
  campaignId String
  groupId    String
  campaign   Campaign        @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  group      MarketingGroup  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  @@id([campaignId, groupId])
}

model CampaignLog {
  id         String   @id @default(cuid())
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contactId  String
  channel    String
  status     String
  error      String?
  sentAt     DateTime @default(now())
  @@index([campaignId])
  @@index([campaignId, status])
}

